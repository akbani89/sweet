# Database
DATABASE_URL=postgresql://glucosnap:glucosnap@localhost:5432/glucosnap

# Auth
SECRET_KEY=change-this-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OTP
OTP_EXPIRE_MINUTES=10
DEV_MODE=true  # Set false in production (OTP returned in response when true)

# Storage: "local" or "s3"
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads

# AWS S3 (only needed if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Cloudflare R2 (optional — if using R2 instead of S3, set this + S3 keys above)
R2_ENDPOINT_URL=
